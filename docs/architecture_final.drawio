        <mxCell id="output1" value="★ output/销售分析报告_*.pptx (最终报告)&lt;br&gt;• templates/placeholders.json (动态更新)&lt;br&gt;• templates/stats_rules.json (动态更新)&lt;br&gt;&lt;br&gt;注：临时文件已清理，不保留" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1F4E79;fillColor=#EBF5FB;fontSize=12;align=left;verticalAlign=top;spacingLeft=4;spacingTop=2" parent="1" vertex="1">
