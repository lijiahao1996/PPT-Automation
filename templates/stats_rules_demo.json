{
  "version": "1.0",
  "description": "Demo 配置 - 客户年龄分布散点图分析",
  "last_updated": "2026-04-09",
  "stats_sheets": {
    "客户年龄分布": {
      "description": "客户年龄与销售额分布分析",
      "type": "distribution",
      "enabled": true,
      "group_by": ["年龄段", "客户类型"],
      "metrics": [
        {"field": "销售额", "agg": "sum", "alias": "总销售额"},
        {"field": "销售额", "agg": "count", "alias": "订单数"},
        {"field": "销售额", "agg": "mean", "alias": "客单价"},
        {"field": "订单数", "agg": "count", "alias": "订单数量"}
      ],
      "sort_by": "总销售额",
      "sort_asc": false
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}
