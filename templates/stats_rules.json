{
  "version": "1.0",
  "description": "统计规则配置 - 新增图表只需修改此文件",
  "last_updated": "2026-04-07",
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "总支付金额"
        },
        {
          "field": "支付金额 (元)",
          "agg": "count",
          "alias": "总订单数"
        },
        {
          "field": "支付金额 (元)",
          "agg": "mean",
          "alias": "平均订单金额"
        },
        {
          "field": "单价 (元)",
          "agg": "sum",
          "alias": "商品总单价"
        },
        {
          "field": "购买数量",
          "agg": "sum",
          "alias": "总购买数量"
        }
      ]
    },
    "城市销售排名": {
      "description": "各城市销售额排名",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "城市"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "城市总销售额"
        },
        {
          "field": "支付金额 (元)",
          "agg": "count",
          "alias": "城市订单数"
        }
      ]
    },
    "商品类别占比": {
      "description": "商品类别销售额占比分析",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "商品类别"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "类别销售额"
        }
      ]
    },
    "性别与订单对比": {
      "description": "不同性别用户订单行为对比",
      "type": "comparison",
      "enabled": true,
      "group_by": [
        "性别"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "性别总支付金额"
        },
        {
          "field": "支付金额 (元)",
          "agg": "mean",
          "alias": "性别平均订单金额"
        },
        {
          "field": "购买数量",
          "agg": "sum",
          "alias": "性别总购买数量"
        }
      ]
    },
    "订单日期趋势": {
      "description": "按日/月订单金额趋势分析",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "订单日期"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "日销售额"
        },
        {
          "field": "支付金额 (元)",
          "agg": "count",
          "alias": "日订单数"
        }
      ]
    },
    "订单状态分布": {
      "description": "订单状态分布情况",
      "type": "distribution",
      "enabled": true,
      "group_by": [
        "订单状态"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    },
    "支付方式-商品类别矩阵": {
      "description": "不同支付方式在各商品类别的使用情况",
      "type": "matrix",
      "enabled": true,
      "group_by": [
        "支付方式",
        "商品类别"
      ],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "sum",
          "alias": "支付金额"
        }
      ]
    },
    "异常订单检测": {
      "description": "识别高金额或异常数量订单",
      "type": "outlier",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "支付金额 (元)",
          "agg": "max",
          "alias": "最高支付金额"
        },
        {
          "field": "购买数量",
          "agg": "max",
          "alias": "最大购买数量"
        }
      ]
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}