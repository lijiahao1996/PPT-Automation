{
  "version": "1.0",
  "description": "统计规则配置 - 新增图表只需修改此文件",
  "last_updated": "2026-04-07",
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "总订单数"
        },
        {
          "field": "销售额",
          "agg": "mean",
          "alias": "平均客单价"
        },
        {
          "field": "销售额",
          "agg": "max",
          "alias": "最高单笔销售额"
        }
      ]
    },
    "销售员业绩排名": {
      "description": "按销售员汇总销售额与订单数进行排名",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "销售员"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    },
    "城市销售占比": {
      "description": "各城市销售额占比分析",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "城市"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    },
    "客户属性对比": {
      "description": "新客与其他客户属性（如后续可能出现的老客）的销售对比",
      "type": "comparison",
      "enabled": true,
      "group_by": [
        "客户属性"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    },
    "月度销售趋势": {
      "description": "按订单时间（月粒度）分析销售额趋势",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "年月"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        }
      ]
    },
    "销售员-产品矩阵": {
      "description": "销售员与产品交叉维度的销售额汇总",
      "type": "matrix",
      "enabled": true,
      "group_by": [
        "销售员",
        "产品"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    },
    "异常订单检测": {
      "description": "识别销售额显著偏离均值的异常订单",
      "type": "outlier",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}