{
  "version": "1.0",
  "description": "统计规则配置 - 新增图表只需修改此文件",
  "last_updated": "2026-04-07",
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标",
      "type": "kpi",
      "enabled": true,
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额",
          "unit": "元"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "总订单数",
          "unit": "单"
        },
        {
          "field": "销售额",
          "agg": "mean",
          "alias": "平均客单价",
          "unit": "元"
        },
        {
          "field": "销售额",
          "agg": "max",
          "alias": "最高单额",
          "unit": "元"
        },
        {
          "field": "销售额",
          "agg": "min",
          "alias": "最低单额",
          "unit": "元"
        }
      ]
    },
    "AI 测试规则": {
      "description": "测试规则",
      "type": "kpi",
      "enabled": true,
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        }
      ]
    },
    "AI_Test_Rule": {
      "description": "Test Rule",
      "type": "kpi",
      "enabled": true,
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        }
      ]
    },
    "销售员排名": {
      "description": "按维度排名统计",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "销售员"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    },
    "产品占比": {
      "description": "按维度占比分析",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "产品"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    },
    "城市排名": {
      "description": "按维度排名统计",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "城市"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    },
    "客户类型对比": {
      "description": "按维度对比分析",
      "type": "comparison",
      "enabled": true,
      "group_by": [
        "客户类型"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        },
        {
          "field": "销售额",
          "agg": "mean",
          "alias": "客单价"
        }
      ]
    },
    "月度趋势": {
      "description": "月度销售趋势分析",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "年月"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单数"
        }
      ]
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}