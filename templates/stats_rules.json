{
  "version": "1.0",
  "description": "统计规则配置 - 新增图表只需修改此文件",
  "last_updated": "2026-04-07",
  "stats_sheets": {
    "核心 KPI": {
      "name": "核心 KPI",
      "type": "kpi",
      "enabled": true,
      "description": "核心经营指标汇总",
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "总订单数"
        },
        {
          "field": "客单价(元)",
          "agg": "mean",
          "alias": "平均客单价"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "平均复购率"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "新增客户总数"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "平均退货率"
        }
      ]
    },
    "客户分段排名": {
      "name": "客户分段排名",
      "type": "ranking",
      "enabled": true,
      "description": "按客户分段统计业绩并排名",
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "分段销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "分段订单数"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "分段新增客户数"
        }
      ]
    },
    "客户分段占比": {
      "name": "客户分段占比",
      "type": "composition",
      "enabled": true,
      "description": "各客户分段对核心指标的贡献占比",
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "销售额"
        }
      ],
      "add_percentage": true
    },
    "月度趋势": {
      "name": "月度趋势",
      "type": "trend",
      "enabled": true,
      "description": "关键指标月度变化趋势",
      "group_by": [
        "月份"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "月销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "月订单数"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "月平均复购率"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "月平均退货率"
        }
      ]
    },
    "客户分段 vs 复购率对比": {
      "name": "客户分段 vs 复购率对比",
      "type": "comparison",
      "enabled": true,
      "description": "不同客户分段的复购率与退货率对比",
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "平均复购率"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "平均退货率"
        }
      ]
    },
    "异常检测：销售额波动": {
      "name": "异常检测：销售额波动",
      "type": "outlier",
      "enabled": true,
      "description": "识别销售额显著偏离均值的月份",
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "月销售额"
        }
      ]
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}