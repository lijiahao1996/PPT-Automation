{
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "总订单数"
        },
        {
          "field": "客单价(元)",
          "agg": "mean",
          "alias": "平均客单价"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "平均复购率"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "新增客户总数"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "平均退货率"
        }
      ]
    },
    "客户分段排名": {
      "description": "按客户分段的销售表现排名",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "分段总销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "分段总订单数"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "分段新增客户数"
        }
      ]
    },
    "客户分段占比": {
      "description": "各客户分段对核心指标的贡献占比",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    },
    "月度趋势": {
      "description": "关键指标月度变化趋势",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "月份"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "月销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "月订单数"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "月平均复购率"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "月平均退货率"
        }
      ]
    },
    "复购率与新客户对比": {
      "description": "复购率与新客户数的关联分析",
      "type": "comparison",
      "enabled": true,
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "平均复购率"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "新客户总数"
        }
      ]
    }
  }
}