{
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "销售额",
          "agg": "count",
          "alias": "订单总数"
        },
        {
          "field": "销售额",
          "agg": "mean",
          "alias": "平均单笔销售额"
        }
      ]
    },
    "按销售员排名": {
      "description": "销售员业绩排名统计",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "销售员"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "总销售额"
        }
      ]
    },
    "按城市销售占比": {
      "description": "各城市销售额占比分析",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "城市"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "城市销售额"
        }
      ]
    },
    "按产品销售对比": {
      "description": "不同产品维度的销售对比（当前仅苹果汁，可扩展）",
      "type": "comparison",
      "enabled": true,
      "group_by": [
        "产品"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "产品销售额"
        }
      ]
    },
    "月度销售趋势": {
      "description": "按年月粒度的销售趋势分析",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "年月"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "月度总销售额"
        }
      ]
    },
    "销售员-产品矩阵": {
      "description": "销售员与产品交叉维度的销售表现",
      "type": "matrix",
      "enabled": true,
      "group_by": [
        "销售员",
        "产品"
      ],
      "metrics": [
        {
          "field": "销售额",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    }
  }
}