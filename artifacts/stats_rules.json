{
  "version": "1.0",
  "description": "统计规则配置 - 新增图表只需修改此文件",
  "last_updated": "2026-04-07",
  "stats_sheets": {
    "核心 KPI": {
      "description": "核心经营指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "总订单数"
        },
        {
          "field": "客单价(元)",
          "agg": "mean",
          "alias": "平均客单价"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "平均复购率"
        },
        {
          "field": "新客户数",
          "agg": "sum",
          "alias": "总新客户数"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "平均退货率"
        }
      ]
    },
    "客户分段排名": {
      "description": "按客户分段的销售业绩排名",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "总销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "总订单数"
        }
      ]
    },
    "客户分段占比": {
      "description": "各客户分段销售额占比分析",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "客户分段"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "销售额"
        }
      ]
    },
    "月度趋势": {
      "description": "关键指标月度趋势分析",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "月份"
      ],
      "metrics": [
        {
          "field": "销售额(元)",
          "agg": "sum",
          "alias": "月销售额"
        },
        {
          "field": "订单数",
          "agg": "sum",
          "alias": "月订单数"
        },
        {
          "field": "复购率(%)",
          "agg": "mean",
          "alias": "月平均复购率"
        },
        {
          "field": "退货率(%)",
          "agg": "mean",
          "alias": "月平均退货率"
        }
      ]
    }
  },
  "global_settings": {
    "decimal_places": 2,
    "thousands_separator": true,
    "output_dir": "output",
    "output_filename": "销售统计汇总.xlsx"
  }
}