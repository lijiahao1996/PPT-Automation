{
  "stats_sheets": {
    "核心 KPI": {
      "description": "员工核心人力指标汇总",
      "type": "kpi",
      "enabled": true,
      "group_by": [],
      "metrics": [
        {
          "field": "年龄",
          "agg": "mean",
          "alias": "平均年龄"
        },
        {
          "field": "月薪 (元)",
          "agg": "sum",
          "alias": "总月薪支出"
        },
        {
          "field": "月薪 (元)",
          "agg": "mean",
          "alias": "平均月薪"
        },
        {
          "field": "月薪 (元)",
          "agg": "max",
          "alias": "最高月薪"
        },
        {
          "field": "月薪 (元)",
          "agg": "min",
          "alias": "最低月薪"
        }
      ]
    },
    "部门业绩排名": {
      "description": "各部门薪资与人力分布排名",
      "type": "ranking",
      "enabled": true,
      "group_by": [
        "部门"
      ],
      "metrics": [
        {
          "field": "月薪 (元)",
          "agg": "sum",
          "alias": "部门总月薪"
        },
        {
          "field": "月薪 (元)",
          "agg": "mean",
          "alias": "部门平均月薪"
        },
        {
          "field": "年龄",
          "agg": "mean",
          "alias": "部门平均年龄"
        },
        {
          "field": "用户 ID",
          "agg": "count",
          "alias": "部门人数"
        }
      ]
    },
    "部门构成分析": {
      "description": "各部门在总人力与薪酬中的占比",
      "type": "composition",
      "enabled": true,
      "group_by": [
        "部门"
      ],
      "metrics": [
        {
          "field": "用户 ID",
          "agg": "count",
          "alias": "部门人数"
        },
        {
          "field": "月薪 (元)",
          "agg": "sum",
          "alias": "部门总月薪"
        }
      ]
    },
    "入职时间趋势": {
      "description": "按年月维度的入职人数与平均月薪趋势",
      "type": "trend",
      "enabled": true,
      "group_by": [
        "入职日期"
      ],
      "metrics": [
        {
          "field": "用户 ID",
          "agg": "count",
          "alias": "当月入职人数"
        },
        {
          "field": "月薪 (元)",
          "agg": "mean",
          "alias": "当月入职员工平均月薪"
        }
      ]
    },
    "年龄-部门矩阵": {
      "description": "各部门员工年龄分布矩阵",
      "type": "matrix",
      "enabled": true,
      "group_by": [
        "部门",
        "年龄"
      ],
      "metrics": [
        {
          "field": "用户 ID",
          "agg": "count",
          "alias": "人数"
        }
      ]
    }
  }
}