# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/

# 配置文件（包含敏感信息）
# 使用 config.ini.example 作为模板
config.ini
.env
*.key
*.pem

# ========== 输出文件管理 ==========
# 输出文件（运行时生成，不提交）
output/*.xlsx
output/*.pptx
output/*.json

# 临时文件（运行时生成，不提交）
artifacts/*
!artifacts/.gitkeep
!artifacts/stats_rules.json
!artifacts/placeholders.json

# 原始数据（敏感数据，不提交）
# 如需共享数据样本，请手动添加脱敏版本
# output/帆软销售明细.xlsx

# 日志（运行时生成，不提交）
logs/*.log
logs/*.txt

# 用户上传资源（不提交，用户自行管理）
resources/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db
